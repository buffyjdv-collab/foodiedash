# ============================================================
# FoodieDash — Environment Variables
# ============================================================
# Copy this file to .env for local dev, or set these in your
# Vercel project settings (Project → Settings → Environment Variables).
# ============================================================

# ---------------------------------------------------------
# Database (Neon PostgreSQL)
# ---------------------------------------------------------
# Get this from your Neon dashboard → Connection Details.
# Use the POOLED connection string (with -pooler in the hostname)
# for serverless platforms like Vercel.
DATABASE_URL="postgresql://user:password@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require"

# ---------------------------------------------------------
# Z.AI SDK (AI chatbot + smart search)
# ---------------------------------------------------------
# These power the "Foodie AI" chatbot and AI smart search.
# If not set, the app builds fine but AI features return errors.
ZAI_BASE_URL="https://internal-api.z.ai/v1"
ZAI_API_KEY="your-z-ai-api-key"
ZAI_CHAT_ID="optional-chat-id"
ZAI_TOKEN="optional-token"
ZAI_USER_ID="optional-user-id"

# ---------------------------------------------------------
# Next.js
# ---------------------------------------------------------
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"
